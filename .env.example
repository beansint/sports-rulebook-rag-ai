# ─── Supabase ─────────────────────────────────────────────────────────────────
# Browser client (NEXT_PUBLIC_ prefix required for client-side access)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-key

# Server / API routes (same values, no NEXT_PUBLIC_ prefix)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=replace-with-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# ─── Auth ─────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=you@example.com
ADMIN_API_KEY=replace-with-long-random-admin-secret

# ─── Embeddings ───────────────────────────────────────────────────────────────
# Embeddings use Mistral mistral-embed (1024-dim) via the OpenAI-compatible API.
# Sign up free at console.mistral.ai — no credit card required.
EMBEDDING_API_KEY=replace-with-mistral-api-key
# EMBEDDING_BASE_URL defaults to https://api.mistral.ai/v1 — override for local Ollama:
# EMBEDDING_BASE_URL=http://localhost:11434/v1
# EMBEDDING_MODEL defaults to mistral-embed — override to use a different model:
# EMBEDDING_MODEL=mistral-embed

# IMPORTANT: switching embedding providers or dimensions requires:
#   1. A DB migration (supabase migration new ...) to change vector(1024) to the new size
#   2. A full re-ingest of all rulebook PDFs
# See doc/ARCHITECTURE.md for details.

# ─── Generation (multi-LLM) ───────────────────────────────────────────────────
# Set keys for whichever providers are enabled in the models table.
# CEREBRAS_API_KEY=replace-with-cerebras-api-key   # free tier: 1M tokens/day

# Optional overrides (defaults pulled from models table / settings table)
DEFAULT_CHAT_MODEL=gpt-oss-120b
